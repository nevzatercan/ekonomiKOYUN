# ──────────────────────────────────────────────
# ekonomiKOYUN Backend — Ortam Değişkenleri
# Bu dosyayı kopyalayıp .env olarak kaydet:
#   cp .env.example .env
# .env dosyası git'e commit'lenmez (.gitignore'da).
# ──────────────────────────────────────────────

# Uygulama ortamı: development | production | test
NODE_ENV=development

# Sunucu portu (default: 3001)
PORT=3001

# SQLite veritabanı dosya yolu
# Relative yollar backend/ klasörüne göredir
DATABASE_URL=./data/ekonomikoyun.db

# ── Faz 2'de eklenecekler ──────────────────────

# Steam API anahtarı (https://steamcommunity.com/dev/apikey)
# STEAM_API_KEY=

# Epic Games / GOG API bilgileri (ileride)
# EPIC_CLIENT_ID=
# EPIC_CLIENT_SECRET=

# Rate limiting (istek/dakika)
# RATE_LIMIT_RPM=60

# Cron job zamanlamaları (cron syntax)
# PRICE_UPDATE_CRON="0 */6 * * *"      # 6 saatte bir fiyat güncelle
# SUBSCRIPTION_UPDATE_CRON="0 2 * * 1" # Pazartesi 02:00 abonelik katalog güncelle

# Log seviyesi: error | warn | info | debug
# LOG_LEVEL=info
